


# MedRAG Backend Configuration

# ═══════════════════════════════════════════════════════════════
#  Hugging Face (DISABLED)
#
#  This backend is configured to use Groq only.
#  HF variables are left here for reference but are not used.
# ═══════════════════════════════════════════════════════════════
# HF_TOKEN=
# HF_MODEL=aaditya/Llama3-OpenBioLLM-70B

# ═══════════════════════════════════════════════════════════════
#  STEP 2: Groq API  (FREE — FALLBACK, very fast)
#  Same Llama-3 70B architecture, runs on Groq's LPU servers.
#  Free tier: 500 req/day, 6000 tokens/min
#
#  Get free key → https://console.groq.com/keys
# ═══════════════════════════════════════════════════════════════
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# ─── LLM backend ─────────────────────────────────────────────
# Groq-only mode (HF is disabled in code).
LLM_BACKEND=groq

# ─── Retry / Timeout ──────────────────────────────────────────
# HF_TIMEOUT is unused in Groq-only mode.
HF_TIMEOUT=120
GROQ_TIMEOUT=60
LLM_MAX_RETRIES=3

# ─── Entrez (PubMed) — FREE ───────────────────────────────────
ENTREZ_EMAIL=

# ─── Embedding Model (runs locally, ~420 MB, CPU-only fine) ───
EMBED_MODEL=pritamdeka/S-PubMedBert-MS-MARCO

# ─── Cross-Encoder Reranker (local, CPU, ~90 MB) ──────────────
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── Data Storage ─────────────────────────────────────────────
DATA_DIR=./data

# ─── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
