


# MedRAG Backend Configuration

# ═══════════════════════════════════════════════════════════════
#  STEP 1: HuggingFace Inference API  (FREE — PRIMARY LLM)
#  Model: aaditya/Llama3-OpenBioLLM-70B runs on HF servers.
#  Your machine needs 0 GPU.
#
#  Get free token → https://huggingface.co/settings/tokens
#  Accept model licence → https://huggingface.co/aaditya/Llama3-OpenBioLLM-70B
# ═══════════════════════════════════════════════════════════════
HF_TOKEN=
HF_MODEL=aaditya/Llama3-OpenBioLLM-70B

# ═══════════════════════════════════════════════════════════════
#  STEP 2: Groq API  (FREE — FALLBACK, very fast)
#  Same Llama-3 70B architecture, runs on Groq's LPU servers.
#  Free tier: 500 req/day, 6000 tokens/min
#
#  Get free key → https://console.groq.com/keys
# ═══════════════════════════════════════════════════════════════
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# ─── Which API to try first ───────────────────────────────────
# "huggingface" → HF first, Groq auto-fallback
# "groq"        → Groq first, HF auto-fallback  (faster, recommended)
LLM_BACKEND=groq

# ─── Retry / Timeout ──────────────────────────────────────────
HF_TIMEOUT=120
GROQ_TIMEOUT=60
LLM_MAX_RETRIES=3

# ─── Entrez (PubMed) — FREE ───────────────────────────────────
ENTREZ_EMAIL=

# ─── Embedding Model (runs locally, ~420 MB, CPU-only fine) ───
EMBED_MODEL=pritamdeka/S-PubMedBert-MS-MARCO

# ─── Cross-Encoder Reranker (local, CPU, ~90 MB) ──────────────
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── Data Storage ─────────────────────────────────────────────
DATA_DIR=./data

# ─── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
